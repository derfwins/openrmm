# OpenRMM Environment Variables

# Backend
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
POSTGRES_HOST=db
POSTGRES_USER=openrmm
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=openrmm
REDIS_HOST=redis

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Agent
AGENT_VERSION=1.0.0

# WebRTC / Remote Desktop
# TURN server for NAT traversal (Coturn recommended)
TURN_SERVER_URL=turn:your-server.com:3478
TURN_USERNAME=openrmm
TURN_PASSWORD=change-me-to-a-secure-turn-password

# Frontend
VITE_API_URL=https://openrmm.derfwins.com